sess#:#event_start_time#:#Startzeit
sess#:#event_static_date#:#Festes Datum
sess#:#sess_no_tutor_select#:#Es wurde kein Referent ausgewählt.
sess#:#il_sess_participant#:#Terminteilnehmer
sess#:#mail_sess_roles#:#Verschicke Mail an folgende Rollen des Termins
